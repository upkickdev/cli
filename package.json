{
  "name": "@upkick/cli",
  "version": "0.1.3",
  "description": "Focused project scaffolding and code generation CLI",
  "license": "MIT",
  "author": "Upkick",
  "homepage": "https://upkick.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/upkickdev/cli.git"
  },
  "bugs": {
    "url": "https://github.com/upkickdev/cli/issues"
  },
  "type": "module",
  "bin": {
    "upkick": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "pnpm check",
    "prepublishOnly": "pnpm check && pnpm build"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.13.1",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "upkick",
    "cli",
    "scaffolding",
    "generator",
    "templates",
    "code-generation"
  ],
  "dependencies": {
    "cac": "^7.0.0",
    "commander": "^14.0.0",
    "picocolors": "^1.1.1",
    "tar": "7.5.20"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/node": "^24.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.10"
  }
}
